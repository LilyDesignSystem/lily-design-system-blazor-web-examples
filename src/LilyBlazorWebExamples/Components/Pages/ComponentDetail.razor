@page "/components/{Slug}"
@using LilyBlazorWebExamples.Data

@if (component is not null)
{
    <p><a href="/components">← Back to components</a></p>
    <h1>@component.Name</h1>
    <p>@component.Description</p>

    <h2>Demo</h2>
    <div class="card" style="padding: 1.5rem;">
        @((MarkupString)component.DemoHtml)
    </div>

    <h2>Details</h2>
    <dl>
        <dt>Name</dt><dd>@component.Name</dd>
        <dt>Slug</dt><dd><code>@component.Slug</code></dd>
        <dt>Description</dt><dd>@component.Description</dd>
    </dl>
    <h2>Usage</h2>
    <pre><code>&lt;@component.Name /&gt;</code></pre>
    <h2>Import</h2>
    <pre><code>@@using LilyBlazorHeadless.Components</code></pre>
}
else
{
    <h1>Component Not Found</h1>
    <p><a href="/components">← Back to components</a></p>
}

@code {
    [Parameter] public string Slug { get; set; } = "";
    private ComponentInfo? component;
    protected override void OnParametersSet()
    {
        component = ComponentData.Components.FirstOrDefault(c => c.Slug == Slug);
    }
}
